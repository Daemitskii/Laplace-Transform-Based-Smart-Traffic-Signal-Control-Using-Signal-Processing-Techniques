// Stoplight 1 Pins 
#define RED_PIN_1 2 
#define YELLOW_PIN_1 3 
#define GREEN_PIN_1 4

// Stoplight 2 Pins 
#define RED_PIN_2 5 
#define YELLOW_PIN_2 6 
#define GREEN_PIN_2 7

// Sensor 1 Pins 
#define TRIG_PIN_1 8 
#define ECHO_PIN_1 9

// Sensor 2 Pins 
#define TRIG_PIN_2 10 
#define ECHO_PIN_2 11

// System Timing & Thresholds
unsigned long minGreen = 10000;      // 10 seconds minimum
unsigned long maxGreen = 30000;      // 30 seconds maximum
float minDetectionThreshold = 10.0;
float maxDetectionThreshold = 100.0;

// Laplace Transform (First-Order Low-Pass Filter) Variables
float tau = 0.5;                     // Time constant (lower = faster response)
float Ts = 0.1;                      // Sample time (approx 100ms loop delay)
float alpha;
float prevActiveDist = 999.0;
float prevCrossDist = 999.0;

void setup() { 
  Serial.begin(9600);

  pinMode(TRIG_PIN_1, OUTPUT); 
  pinMode(ECHO_PIN_1, INPUT);

  pinMode(TRIG_PIN_2, OUTPUT); 
  pinMode(ECHO_PIN_2, INPUT);

  pinMode(RED_PIN_1, OUTPUT); 
  pinMode(YELLOW_PIN_1, OUTPUT); 
  pinMode(GREEN_PIN_1, OUTPUT);

  pinMode(RED_PIN_2, OUTPUT); 
  pinMode(YELLOW_PIN_2, OUTPUT); 
  pinMode(GREEN_PIN_2, OUTPUT);

  // Calculate discrete filter coefficient
  alpha = Ts / (tau + Ts);
}

float readRawDistance(int trigPin, int echoPin) { 
  digitalWrite(trigPin, LOW); 
  delayMicroseconds(2); 
  digitalWrite(trigPin, HIGH); 
  delayMicroseconds(10); 
  digitalWrite(trigPin, LOW); 
  
  // 30000us timeout prevents hardware freeze
  long duration = pulseIn(echoPin, HIGH, 30000); 
  
  if (duration == 0) {
    return 999.0; 
  }
  
  return duration * 0.034 / 2; 
}

void monitorGreenPhase(int activeTrig, int activeEcho, int crossTrig, int crossEcho) {
  unsigned long startTime = millis();
  int emptyLaneCounter = 0;
  int bothLaneCounter = 0;
  int crossLaneCounter = 0;

  // Reset filter baseline for new phase
  prevActiveDist = 999.0;
  prevCrossDist = 999.0;

  while (millis() - startTime < maxGreen) { 
    
    // Read and Filter Active Lane
    float rawActive = readRawDistance(activeTrig, activeEcho);
    float activeDist = prevActiveDist + alpha * (rawActive - prevActiveDist);
    prevActiveDist = activeDist;
    bool activeCar = (activeDist >= minDetectionThreshold) && (activeDist <= maxDetectionThreshold);

    // Acoustic interference prevention delay
    delay(40); 

    // Read and Filter Cross Lane
    float rawCross = readRawDistance(crossTrig, crossEcho);
    float crossDist = prevCrossDist + alpha * (rawCross - prevCrossDist);
    prevCrossDist = crossDist;
    bool crossCar = (crossDist >= minDetectionThreshold) && (crossDist <= maxDetectionThreshold);

    Serial.print("Filtered Active: ");
    Serial.print(activeDist);
    Serial.print(" cm | Filtered Cross: ");
    Serial.print(crossDist);
    Serial.println(" cm");

    bool minTimePassed = (millis() - startTime) >= minGreen;

    if (minTimePassed) {
      if (crossCar && !activeCar) {
        crossLaneCounter++;
        if (crossLaneCounter >= 3) {
          Serial.println("Cross traffic detected. Active empty. Switching.");
          break;
        }
      } else {
        crossLaneCounter = 0;
      }

      if (activeCar && crossCar) {
        bothLaneCounter++;
        if (bothLaneCounter >= 3) {
          Serial.println("Both lanes full. Switching.");
          break; 
        }
      } else {
        bothLaneCounter = 0; 
      }
      
      if (!activeCar && !crossCar) {
        emptyLaneCounter++;
        if (emptyLaneCounter >= 3) {
          Serial.println("Both lanes clear. Switching.");
          break;
        }
      } else {
        emptyLaneCounter = 0; 
      }
    }

    // Remaining delay to approximate Ts = 0.1s
    delay(60); 
  }
}

void loop() { 
  digitalWrite(RED_PIN_1, LOW); 
  digitalWrite(YELLOW_PIN_1, LOW); 
  digitalWrite(GREEN_PIN_1, HIGH);

  digitalWrite(RED_PIN_2, HIGH); 
  digitalWrite(YELLOW_PIN_2, LOW); 
  digitalWrite(GREEN_PIN_2, LOW);

  Serial.println("--- Light 1 is GREEN ---");
  monitorGreenPhase(TRIG_PIN_1, ECHO_PIN_1, TRIG_PIN_2, ECHO_PIN_2);

  digitalWrite(GREEN_PIN_1, LOW); 
  digitalWrite(YELLOW_PIN_1, HIGH);
  delay(2000);

  digitalWrite(YELLOW_PIN_1, LOW); 
  digitalWrite(RED_PIN_1, HIGH);

  digitalWrite(RED_PIN_2, LOW); 
  digitalWrite(GREEN_PIN_2, HIGH);

  Serial.println("--- Light 2 is GREEN ---");
  monitorGreenPhase(TRIG_PIN_2, ECHO_PIN_2, TRIG_PIN_1, ECHO_PIN_1);

  digitalWrite(GREEN_PIN_2, LOW); 
  digitalWrite(YELLOW_PIN_2, HIGH);
  delay(2000); 
}
