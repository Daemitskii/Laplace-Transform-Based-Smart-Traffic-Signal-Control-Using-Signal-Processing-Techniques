// Stoplight 1 Pins 
#define RED_PIN_1 2 
#define YELLOW_PIN_1 3 
#define GREEN_PIN_1 4

// Stoplight 2 Pins 
#define RED_PIN_2 5 
#define YELLOW_PIN_2 6 
#define GREEN_PIN_2 7

// Sensor 1 Pins 
#define TRIG_PIN_1 8 
#define ECHO_PIN_1 9

// Sensor 2 Pins 
#define TRIG_PIN_2 10 
#define ECHO_PIN_2 11

float tau = 2.0;
float Ts = 0.1;
float alpha;

// Variables to keep track of distance smoothing
float filteredDistance1 = 0; 
float previousFiltered1 = 0; 
float filteredDistance2 = 0; 
float previousFiltered2 = 0;

unsigned long minGreen = 10000;      // 10 seconds minimum
unsigned long maxGreen = 60000;     // 60 seconds maximum
float minDetectionThreshold = 1.0;  // Minimum distance in cm
float maxDetectionThreshold = 100.0; // Maximum distance in cm

void setup() { 
  Serial.begin(9600);

  pinMode(TRIG_PIN_1, OUTPUT); 
  pinMode(ECHO_PIN_1, INPUT);

  pinMode(TRIG_PIN_2, OUTPUT); 
  pinMode(ECHO_PIN_2, INPUT);

  pinMode(RED_PIN_1, OUTPUT); 
  pinMode(YELLOW_PIN_1, OUTPUT); 
  pinMode(GREEN_PIN_1, OUTPUT);

  pinMode(RED_PIN_2, OUTPUT); 
  pinMode(YELLOW_PIN_2, OUTPUT); 
  pinMode(GREEN_PIN_2, OUTPUT);

  alpha = Ts / (tau + Ts); 
}

float readDistance(int trigPin, int echoPin) { 
  digitalWrite(trigPin, LOW); 
  delayMicroseconds(2); 
  digitalWrite(trigPin, HIGH); 
  delayMicroseconds(10); 
  digitalWrite(trigPin, LOW); 
  long duration = pulseIn(echoPin, HIGH); 
  float distance = duration * 0.034 / 2; 
  return distance; 
}

// New intelligent function that monitors BOTH sensors during a green light
void monitorGreenPhase(int activeTrig, int activeEcho, float &activeFilt, float &activePrev,
                       int crossTrig, int crossEcho, float &crossFilt, float &crossPrev) {
                         
  unsigned long startTime = millis();

  // Keep green light on up to the maximum 60 seconds
  while (millis() - startTime < maxGreen) { 
    
    // 1. Read the lane that currently has the GREEN light
    float activeDist = readDistance(activeTrig, activeEcho);
    activeFilt = activePrev + alpha * (activeDist - activePrev);
    activePrev = activeFilt;
    bool activeCar = (activeFilt >= minDetectionThreshold) && (activeFilt <= maxDetectionThreshold);

    // 2. Read the lane that currently has the RED light (Cross traffic)
    float crossDist = readDistance(crossTrig, crossEcho);
    crossFilt = crossPrev + alpha * (crossDist - crossPrev);
    crossPrev = crossFilt;
    bool crossCar = (crossFilt >= minDetectionThreshold) && (crossFilt <= maxDetectionThreshold);

    // Has the mandatory minimum 3 seconds passed?
    bool minTimePassed = (millis() - startTime) >= minGreen;

    if (minTimePassed) {
      // RULE 1: If BOTH lanes have cars, force a switch so the other side doesn't wait 60s
      if (activeCar && crossCar) {
        Serial.println("Cars detected on BOTH sides. Proceeding in minimum time (Switching).");
        break; 
      }
      
      // RULE 2: If the current lane is empty, cut the green light early
      if (!activeCar) {
        Serial.println("Active lane is clear. Switching early.");
        break;
      }
      
      // If activeCar is true AND crossCar is false, the loop naturally continues up to 60s
    }

    delay(50); // Small buffer to prevent ultrasonic sensor interference
  }
}

void loop() { 
  // Phase 1: Stoplight 1 is GREEN, Stoplight 2 is RED 
  digitalWrite(RED_PIN_1, LOW); 
  digitalWrite(YELLOW_PIN_1, LOW); 
  digitalWrite(GREEN_PIN_1, HIGH);

  digitalWrite(RED_PIN_2, HIGH); 
  digitalWrite(YELLOW_PIN_2, LOW); 
  digitalWrite(GREEN_PIN_2, LOW);

  Serial.println("--- Light 1 is GREEN ---");
  // Monitor Light 1 as active, Light 2 as cross traffic
  monitorGreenPhase(TRIG_PIN_1, ECHO_PIN_1, filteredDistance1, previousFiltered1,
                    TRIG_PIN_2, ECHO_PIN_2, filteredDistance2, previousFiltered2);

  // Phase 2: Stoplight 1 is YELLOW, Stoplight 2 is RED 
  digitalWrite(GREEN_PIN_1, LOW); 
  digitalWrite(YELLOW_PIN_1, HIGH);
  delay(2000);

  // Phase 3: Stoplight 1 is RED, Stoplight 2 is GREEN 
  digitalWrite(YELLOW_PIN_1, LOW); 
  digitalWrite(RED_PIN_1, HIGH);

  digitalWrite(RED_PIN_2, LOW); 
  digitalWrite(GREEN_PIN_2, HIGH);

  Serial.println("--- Light 2 is GREEN ---");
  // Monitor Light 2 as active, Light 1 as cross traffic
  monitorGreenPhase(TRIG_PIN_2, ECHO_PIN_2, filteredDistance2, previousFiltered2,
                    TRIG_PIN_1, ECHO_PIN_1, filteredDistance1, previousFiltered1);

  // Phase 4: Stoplight 1 is RED, Stoplight 2 is YELLOW 
  digitalWrite(GREEN_PIN_2, LOW); 
  digitalWrite(YELLOW_PIN_2, HIGH);
  delay(2000); 
}
